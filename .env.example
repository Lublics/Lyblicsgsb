# =====================================================
# GSB Reservation - Variables d'environnement
# =====================================================
# Copiez ce fichier en .env et adaptez les valeurs

# --- Base de donnees ---
DB_HOST=localhost
DB_NAME=GSB_Reservation
DB_USER=root
DB_PASS=

# --- Application ---
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# --- Securite ---
SESSION_LIFETIME=120
CORS_ALLOWED_ORIGINS=http://localhost
INIT_TOKEN=gsb_init_secret_2024

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=60

# --- Logging ---
LOG_LEVEL=info
LOG_PATH=./logs/
